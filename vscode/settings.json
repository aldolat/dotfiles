{
    "workbench.colorTheme": "Dracula Theme",
    "workbench.startupEditor": "none",
    "editor.fontSize": 18,
    "editor.fontFamily": "\"JetBrains Mono\", Hack, 'monospace', monospace",
    "editor.fontLigatures": true,
    "workbench.colorCustomizations": {
        "sash.hoverBorder": "#64227c",
        "statusBar.background": "#64227c",
        "statusBar.foreground": "#ffffff"
    },
    "editor.rulers": [
        80
    ],
    "emptyIndent.highlightIndent": true,
    "workbench.iconTheme": "material-icon-theme",
    "telemetry.telemetryLevel": "off",
    "editor.quickSuggestions": {
        "comments": "on"
    },
    "diffEditor.ignoreTrimWhitespace": false,
    "github.gitProtocol": "ssh",
    /* Excluded file types */
    "emptyIndent.exclude": [
        ".md"
    ],
    "chat.commandCenter.enabled": false,
    "explorer.confirmDelete": false,
    "projectManager.git.baseFolders": [
        "/home/aldo/src"
    ],
    "projectManager.git.maxDepthRecursion": 2,
    "settingsSync.ignoredSettings": [

    ],
    "wikitext.wikiparser.enable": true,
    "wikiparser.articlePath": "https://en.wikipedia.org/wiki/",
    "latex-workshop.latex.autoBuild.run": "never",
    "markdown.extension.toc.levels": "2..6",
    "git.confirmSync": false,
    "latex-workshop.intellisense.citation.backend": "biblatex",
    "latex-workshop.latex.recipe.default": "lastUsed",
    "latex-workshop.latex.recipes": [

        {
            "name": "latexmk",
            "tools": [
                "latexmk"
            ]
        },
        {
            "name": "latexmk (latexmkrc)",
            "tools": [
                "latexmk_rconly"
            ]
        },
        {
            "name": "latexmk (lualatex)",
            "tools": [
                "lualatexmk"
            ]
        },
        {
            "name": "latexmk (xelatex)",
            "tools": [
                "xelatexmk"
            ]
        },
        {
            "name": "pdflatex -> bibtex -> pdflatex * 2",
            "tools": [
                "pdflatex",
                "bibtex",
                "pdflatex",
                "pdflatex"
            ]
        },
        {
            "name": "Compile Rnw files",
            "tools": [
                "rnw2tex",
                "latexmk"
            ]
        },
        {
            "name": "Compile Jnw files",
            "tools": [
                "jnw2tex",
                "latexmk"
            ]
        },
        {
            "name": "Compile Pnw files",
            "tools": [
                "pnw2tex",
                "latexmk"
            ]
        },
        {
            "name": "tectonic",
            "tools": [
                "tectonic"
            ]
        }
    ],
}